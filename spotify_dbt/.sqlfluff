[sqlfluff]
templater = dbt
dialect = postgres
sql_file_exts = .sql
max_line_length = 120
exclude_rules = L031, L034

[sqlfluff:templater:dbt]
project_dir = .

[sqlfluff:rules:L010]
capitalisation_policy = upper

[sqlfluff:rules:L014]
extended_capitalisation_policy = lower

[sqlfluff:rules:L016]
max_line_length = 120

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4